{
  "name": "destiny-2-build-optimizer",
  "version": "1.0.0",
  "private": true,
  "description": "Destiny 2 Build Optimizer — Vue3 + FastAPI + Electron",
  "scripts": {
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "cd electron && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "cd electron && npm run build",
    "build": "npm run build:frontend && npm run build:electron"
  }
}
