{
  "name": "d2-optimizer-desktop",
  "version": "1.0.0",
  "description": "Destiny 2 Build Optimizer Desktop Edition",
  "author": "Makka",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.makka.d2optimizer",
    "productName": "Destiny2 Build Optimizer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../frontend/dist/**/*",
      "../backend/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
